# Full WordPress REST API v2 URL.
# Move WordPress to a CMS subdomain before the Next.js frontend takes over the
# primary rankconvert.com.au domain.
WORDPRESS_API_URL=https://cms.rankconvert.com.au/wp-json/wp/v2

# Use a long random value and send it as the x-wordpress-webhook-secret header.
WORDPRESS_REVALIDATE_SECRET=replace-with-a-long-random-secret

